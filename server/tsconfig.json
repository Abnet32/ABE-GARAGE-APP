{
  "compilerOptions": {
    "target": "ES2020", // Modern JS target, supports top-level await
    "module": "ESNext", // ESM modules
    "moduleResolution": "node", // Modern Node module resolution
    "rootDir": "./", // Your source folder
    "outDir": "./dist", // Compiled JS output
    "esModuleInterop": true, // Allows default import from CommonJS
    "allowJs": true, // Allow importing .js files
    "checkJs": false, // Don’t type-check .js files
    "skipLibCheck": true, // Skip type checking of node_modules
    "resolveJsonModule": true, // Allow importing JSON files
    "strict": false // Turn off strict mode (optional)
  },
  "include": [
    "**/*.ts",
    "**/*.js" // Include all JS files
  ],
  "exclude": ["node_modules", "dist"]
}
